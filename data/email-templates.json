[
  {
    "id": "welcome",
    "name": "Welcome Email",
    "subject": "Welcome to {{company_name}}!",
    "category": "Onboarding",
    "html": "\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Welcome</title>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f4f4;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff;\">\n    <tr>\n      <td style=\"padding: 40px 30px; text-align: center; background-color: #f97316;\">\n        <h1 style=\"color: #ffffff; margin: 0;\">Welcome!</h1>\n      </td>\n    </tr>\n    <tr>\n      <td style=\"padding: 40px 30px;\">\n        <h2 style=\"color: #333333; margin-top: 0;\">Hi {{first_name}},</h2>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          Welcome to {{company_name}}! We're excited to have you on board.\n        </p>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          If you have any questions, feel free to reply to this email.\n        </p>\n        <table cellpadding=\"0\" cellspacing=\"0\" style=\"margin: 30px 0;\">\n          <tr>\n            <td style=\"background-color: #f97316; border-radius: 6px;\">\n              <a href=\"{{cta_url}}\" style=\"display: inline-block; padding: 15px 30px; color: #ffffff; text-decoration: none; font-weight: bold;\">\n                Get Started\n              </a>\n            </td>\n          </tr>\n        </table>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          Best regards,<br>\n          The {{company_name}} Team\n        </p>\n      </td>\n    </tr>\n    <tr>\n      <td style=\"padding: 20px 30px; background-color: #f8f8f8; text-align: center;\">\n        <p style=\"color: #999999; font-size: 12px; margin: 0;\">\n          © 2026 {{company_name}}. All rights reserved.\n        </p>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
    "text": "Hi {{first_name}}, Welcome to {{company_name}}! We're excited to have you.",
    "variables": [
      "first_name",
      "company_name",
      "cta_url"
    ],
    "createdAt": "2026-02-17T00:13:22.433Z",
    "updatedAt": "2026-02-17T00:13:22.433Z"
  },
  {
    "id": "follow-up",
    "name": "Follow Up",
    "subject": "Following up on our conversation",
    "category": "Sales",
    "html": "\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f4f4;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff;\">\n    <tr>\n      <td style=\"padding: 40px 30px;\">\n        <h2 style=\"color: #333333; margin-top: 0;\">Hi {{first_name}},</h2>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          I wanted to follow up on our recent conversation about {{topic}}.\n        </p>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          {{custom_message}}\n        </p>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          Let me know if you have any questions or would like to schedule a call.\n        </p>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          Best regards,<br>\n          {{sender_name}}\n        </p>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
    "variables": [
      "first_name",
      "topic",
      "custom_message",
      "sender_name"
    ],
    "createdAt": "2026-02-17T00:13:22.433Z",
    "updatedAt": "2026-02-17T00:13:22.433Z"
  },
  {
    "id": "newsletter",
    "name": "Newsletter",
    "subject": "{{newsletter_title}} - {{month}} Newsletter",
    "category": "Marketing",
    "html": "\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f4f4;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff;\">\n    <tr>\n      <td style=\"padding: 40px 30px; text-align: center; background-color: #1a1a2e;\">\n        <h1 style=\"color: #ffffff; margin: 0;\">{{newsletter_title}}</h1>\n        <p style=\"color: #cccccc; margin-top: 10px;\">{{month}} Edition</p>\n      </td>\n    </tr>\n    <tr>\n      <td style=\"padding: 40px 30px;\">\n        <h2 style=\"color: #333333;\">{{headline}}</h2>\n        <p style=\"color: #666666; line-height: 1.6;\">\n          {{content}}\n        </p>\n        <hr style=\"border: none; border-top: 1px solid #eeeeee; margin: 30px 0;\">\n        <p style=\"color: #999999; font-size: 12px; text-align: center;\">\n          <a href=\"{{unsubscribe_url}}\" style=\"color: #999999;\">Unsubscribe</a>\n        </p>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
    "variables": [
      "newsletter_title",
      "month",
      "headline",
      "content",
      "unsubscribe_url"
    ],
    "createdAt": "2026-02-17T00:13:22.433Z",
    "updatedAt": "2026-02-17T00:13:22.433Z"
  },
  {
    "id": "template-1771622858204",
    "name": "RPG Service Email Template",
    "subject": "Signature Search by Renaissance",
    "html": "<!DOCTYPE html>\n<html lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head>\n  <meta charset=\"UTF-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/>\n  <title>Renaissance Personnel Group</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\"/>\n  <style>\n    /* ── Reset ── */\n    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }\n    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }\n    img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }\n    body { margin:0; padding:0; background:#f0f2f7; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Section Labels (remove before sending) ── */\n    .section-label {\n      background:#fff3cd; border-left:4px solid #f0ad4e;\n      padding:7px 16px; font-size:11px; font-weight:700;\n      color:#856404; letter-spacing:.6px; text-transform:uppercase;\n      font-family:'DM Sans',Arial,sans-serif;\n    }\n\n    /* ── Shared ── */\n    .email-outer { width:100%; background:#f0f2f7; }\n    .email-wrap  { width:660px; margin:0 auto; background:#ffffff; }\n\n    /* ── Header ── */\n    .hdr { background:#ffffff; border-bottom:1px solid #eef0f6; padding:16px 28px; }\n    .hdr-logo { font-family:'Playfair Display',Georgia,serif; font-size:19px; font-weight:800; color:#1a1a2e; }\n    .hdr-logo span { color:#6c5ce7; }\n    .hdr-nav a { font-size:12px; color:#555555; text-decoration:none; margin-left:18px; font-family:'DM Sans',Arial,sans-serif; }\n    .btn-signin { background:#6c5ce7; color:#ffffff !important; padding:8px 17px; border-radius:6px; font-size:12px; font-weight:700; text-decoration:none !important; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Hero ── */\n    .hero { background:linear-gradient(135deg,#f5f4ff 0%,#ece9ff 100%); padding:48px 36px 40px; }\n    .hero-badge { display:inline-block; background:rgba(108,92,231,.13); color:#6c5ce7; font-size:11px; font-weight:700; padding:5px 14px; border-radius:20px; letter-spacing:.5px; text-transform:uppercase; font-family:'DM Sans',Arial,sans-serif; margin-bottom:16px; }\n    .hero h1 { font-family:'Playfair Display',Georgia,serif; font-size:36px; font-weight:800; line-height:1.15; color:#1a1a2e; margin:0 0 12px; }\n    .hero h1 span { color:#6c5ce7; }\n    .hero p { font-size:14px; color:#555; line-height:1.7; margin:0 0 26px; font-family:'DM Sans',Arial,sans-serif; }\n    .search-wrap { background:#ffffff; border-radius:10px; padding:8px; box-shadow:0 4px 20px rgba(108,92,231,.15); display:inline-table; width:100%; max-width:460px; }\n    .search-input { border:none; outline:none; font-size:13px; color:#333; padding:8px 10px; font-family:'DM Sans',Arial,sans-serif; background:transparent; width:200px; }\n    .search-btn { background:#6c5ce7; color:#fff; border:none; border-radius:7px; padding:10px 20px; font-size:13px; font-weight:700; font-family:'DM Sans',Arial,sans-serif; cursor:pointer; }\n    .hero-tag { background:#fff; border:1px solid #e0e0e0; border-radius:20px; padding:3px 10px; font-size:11px; color:#666; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Logo strip ── */\n    .logo-strip { background:#ffffff; padding:18px 36px; border-bottom:1px solid #eef0f6; }\n    .partner-name { font-size:11px; font-weight:700; color:#cccccc; letter-spacing:1px; text-transform:uppercase; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Section wrapper ── */\n    .section { padding:40px 36px; }\n    .section-bg { padding:40px 36px; background:#f8f7ff; }\n    .sec-title { font-family:'Playfair Display',Georgia,serif; font-size:26px; font-weight:800; color:#1a1a2e; margin:0 0 22px; }\n    .sec-title span { color:#6c5ce7; }\n    .browse-all { font-size:12px; color:#6c5ce7; font-weight:700; text-decoration:none; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Category cards ── */\n    .cat-card { background:#f8f7ff; border:1px solid #ede9ff; border-radius:10px; padding:16px 10px; text-align:center; text-decoration:none; display:block; }\n    .cat-name { font-size:12px; font-weight:700; color:#1a1a2e; margin:8px 0 3px; font-family:'DM Sans',Arial,sans-serif; }\n    .cat-count { font-size:11px; color:#999999; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── CTA banner ── */\n    .cta-wrap { background:linear-gradient(135deg,#6c5ce7 0%,#8a7ef7 100%); padding:44px 36px; text-align:center; }\n    .cta-wrap h2 { font-family:'Playfair Display',Georgia,serif; font-size:28px; font-weight:800; color:#fff; margin:0 0 10px; }\n    .cta-wrap p { font-size:13px; color:rgba(255,255,255,.82); line-height:1.6; margin:0 auto 22px; max-width:380px; font-family:'DM Sans',Arial,sans-serif; }\n    .btn-cta { border:2px solid #fff; color:#fff !important; padding:12px 28px; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none !important; font-family:'DM Sans',Arial,sans-serif; display:inline-block; }\n\n    /* ── Job cards (4-col) ── */\n    .job-card { border:1px solid #eef0f6; border-radius:10px; padding:14px; background:#ffffff; }\n    .job-icon-wrap { width:34px; height:34px; background:#f0f2f7; border-radius:8px; display:inline-block; vertical-align:middle; text-align:center; line-height:34px; }\n    .job-badge { font-size:10px; font-weight:700; color:#6c5ce7; background:rgba(108,92,231,.1); padding:3px 8px; border-radius:20px; letter-spacing:.5px; text-transform:uppercase; vertical-align:middle; margin-left:6px; font-family:'DM Sans',Arial,sans-serif; }\n    .job-title { font-size:13px; font-weight:700; color:#1a1a2e; margin:9px 0 4px; font-family:'DM Sans',Arial,sans-serif; }\n    .job-desc { font-size:11px; color:#999999; line-height:1.55; margin:0 0 9px; font-family:'DM Sans',Arial,sans-serif; }\n    .job-more { font-size:11px; font-weight:700; color:#6c5ce7; text-decoration:none; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Latest job rows ── */\n    .latest-row { border:1px solid #eef0f6; border-radius:10px; padding:13px 14px; background:#ffffff; margin-bottom:10px; }\n    .lj-icon { width:38px; height:38px; background:#f0f2f7; border-radius:8px; display:inline-block; text-align:center; line-height:38px; vertical-align:top; }\n    .meta-tag { font-size:10px; font-weight:600; color:#aaaaaa; text-transform:uppercase; letter-spacing:.3px; font-family:'DM Sans',Arial,sans-serif; margin-right:8px; }\n    .lj-title { font-size:13px; font-weight:700; color:#1a1a2e; margin:3px 0; font-family:'DM Sans',Arial,sans-serif; }\n    .lj-sub { font-size:11px; color:#aaaaaa; font-family:'DM Sans',Arial,sans-serif; }\n    .lj-loc { font-size:11px; color:#bbbbbb; text-align:right; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Footer ── */\n    .footer { background:#1a1a2e; padding:36px; }\n    .f-logo { font-family:'Playfair Display',Georgia,serif; font-size:17px; font-weight:800; color:#ffffff; margin-bottom:8px; }\n    .f-logo span { color:#6c5ce7; }\n    .f-tag { font-size:11px; color:rgba(255,255,255,.45); line-height:1.6; margin-bottom:14px; font-family:'DM Sans',Arial,sans-serif; }\n    .f-social { width:28px; height:28px; background:rgba(255,255,255,.1); border-radius:50%; display:inline-block; text-align:center; line-height:28px; color:#fff; text-decoration:none; font-size:12px; font-weight:700; font-family:'DM Sans',Arial,sans-serif; margin-right:5px; }\n    .f-heading { font-size:12px; font-weight:700; color:#ffffff; margin-bottom:12px; font-family:'DM Sans',Arial,sans-serif; }\n    .f-link { font-size:11px; color:rgba(255,255,255,.45); text-decoration:none; display:block; margin-bottom:7px; font-family:'DM Sans',Arial,sans-serif; }\n    .f-nl p { font-size:11px; color:rgba(255,255,255,.45); line-height:1.6; margin-bottom:10px; font-family:'DM Sans',Arial,sans-serif; }\n    .nl-input { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); border-radius:6px; padding:9px 10px; font-size:11px; color:#fff; width:140px; font-family:'DM Sans',Arial,sans-serif; }\n    .nl-btn { background:#6c5ce7; color:#fff; border:none; border-radius:6px; padding:9px 14px; font-size:11px; font-weight:700; font-family:'DM Sans',Arial,sans-serif; cursor:pointer; }\n    .f-bottom { border-top:1px solid rgba(255,255,255,.08); padding-top:18px; margin-top:28px; font-size:10px; color:rgba(255,255,255,.3); text-align:center; font-family:'DM Sans',Arial,sans-serif; }\n\n    /* ── Spacer utility ── */\n    .sp8 { height:8px; } .sp12 { height:12px; } .sp16 { height:16px; } .sp24 { height:24px; }\n  </style>\n</head>\n<body>\n<table class=\"email-outer\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">\n<tr><td align=\"center\" style=\"padding:30px 10px;\">\n\n  <table class=\"email-wrap\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"660\" style=\"border-radius:16px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.10);\">\n\n    <!-- ══════════════════════════════════════════\n         SECTION LABEL: HEADER\n         Remove this row before sending\n    ══════════════════════════════════════════ -->\n    <tr><td class=\"section-label\">📌 HEADER — Replace logo name, nav links, and Sign In URL</td></tr>\n\n    <!-- HEADER -->\n    <tr><td class=\"hdr\">\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">\n        <tr>\n          <td><div class=\"hdr-logo\">Renaissance <span>Personnel</span></div></td>\n          <td align=\"right\" class=\"hdr-nav\">\n            <a href=\"[FIND_JOBS_URL]\">Find Jobs</a>\n            <a href=\"[LATEST_JOBS_URL]\">Latest Jobs</a>\n            <a href=\"[COMPANIES_URL]\">Browse Companies</a>\n            <a href=\"[SIGNIN_URL]\" class=\"btn-signin\">Sign In</a>\n          </td>\n        </tr>\n      </table>\n    </td></tr>\n\n    <!-- ══════════════════════════════════════════\n         SECTION LABEL: HERO\n    ══════════════════════════════════════════ -->\n    <tr><td class=\"section-label\">🦸 HERO — Replace headline, subheadline, search bar, tag chips</td></tr>\n\n    <!-- HERO -->\n    <tr><td class=\"hero\">\n      <div class=\"hero-badge\">🔍 Now Hiring Across [INDUSTRY / LOCATION]</div>\n      <h1>Explore Over <span>[X,000+]<br/>Job Opportunities</span></h1>\n      <p>[SUBHEADLINE — e.g., \"Discover top talent and career opportunities tailored for your industry. Connect with companies that value what you bring to the table.\"]</p>\n      <!-- Search bar -->\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#fff;border-radius:10px;padding:8px;box-shadow:0 4px 20px rgba(108,92,231,.15);\">\n        <tr>\n          <td><input class=\"search-input\" type=\"text\" placeholder=\"Job title, keyword...\"/></td>\n          <td><input class=\"search-input\" type=\"text\" placeholder=\"Location\"/></td>\n          <td><button class=\"search-btn\">Search</button></td>\n        </tr>\n      </table>\n      <!-- Tags -->\n      <div style=\"margin-top:12px;font-size:12px;color:#888;font-family:'DM Sans',Arial,sans-serif;\">\n        Popular:\n        <span class=\"hero-tag\">[Tag 1]</span>\n        <span class=\"hero-tag\">[Tag 2]</span>\n        <span class=\"hero-tag\">[Tag 3]</span>\n        <span class=\"hero-tag\">[Tag 4]</span>\n      </div>\n    </td></tr>\n\n    <!-- ══════════════════════════════════════════\n         SECTION LABEL: PARTNER LOGO STRIP\n    ══════════════════════════════════════════ -->\n    <tr><td class=\"section-label\">🏢 LOGO STRIP — Replace with client/partner company names or logos</td></tr>\n\n    <!-- LOGO STRIP -->\n    <tr><td class=\"logo-strip\">\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">\n        <tr>\n          <td align=\"center\"><span class=\"partner-name\">[Partner 1]</span></td>\n          <td align=\"center\"><span class=\"partner-name\">[Partner 2]</span></td>\n          <td align=\"center\"><span class=\"partner-name\">[Partner 3]</span></td>\n          <td align=\"center\"><span class=\"partner-name\">[Partner 4]</span></td>\n          <td align=\"center\"><span class=\"partner-name\">[Partner 5]</span></td>\n        </tr>\n      </table>\n    </td></tr>\n\n    <!-- ══════════════════════════════════════════\n         SECTION LABEL: CATEGORIES (4-col grid)\n    ══════════════════════════════════════════ -->\n    <tr><td class=\"section-label\">📂 CATEGORIES — Replace icons, names, job counts, and link URLs. 4 per row.</td></tr>\n\n    <!-- CATEGORIES -->\n    <tr><td class=\"section\">\n      <div class=\"sec-title\">Explore by <span>Category</span></div>\n\n      <!-- ROW 1 -->\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">\n        <tr>\n          <!-- Design -->\n          <td width=\"25%\" style=\"padding:0 5px 10px 0;\">\n            <a href=\"[CATEGORY_URL]\" class=\"cat-card\">\n              <div style=\"margin:0 auto;width:36px;height:36px;background:rgba(108,92,231,.08);border-radius:8px;display:flex;align-items:center;justify-content:center;\">\n                <!-- Icon: pen-tool -->\n                <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6c5ce7\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 19l7-7 3 3-7 7-3-3z\"/><path d=\"M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z\"/><path d=\"M2 2l7.586 7.586\"/><circle cx=\"11\" cy=\"11\" r=\"2\"/></svg>\n              </div>\n              <div class=\"cat-name\">[Design]</div>\n              <div class=\"cat-count\">[235] Jobs Available</div>\n            </a>\n          </td>\n          <!-- Analyst -->\n          <td width=\"25%\" style=\"padding:0 5px 10px;\">\n            <a href=\"[CATEGORY_URL]\" class=\"cat-card\">\n              <div style=\"margin:0 auto;width:36px;height:36px;background:rgba(108,92,231,.08);border-radius:8px;display:flex;align-items:center;justify-content:center;\">\n                <!-- Icon: bar-chart-2 -->\n                <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6c5ce7\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/></svg>\n              </div>\n              <div class=\"cat-name\">[Analyst]</div>\n              <div class=\"cat-count\">[235] Jobs Available</div>\n            </a>\n          </td>\n          <!-- Electrician -->\n          <td width=\"25%\" style=\"padding:0 5px 10px;\">\n            <a href=\"[CATEGORY_URL]\" class=\"cat-card\">\n              <div style=\"margin:0 auto;width:36px;height:36px;background:rgba(108,92,231,.08);border-radius:8px;display:flex;align-items:center;justify-content:center;\">\n                <!-- Icon: zap -->\n                <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6c5ce7\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/></svg>\n              </div>\n              <div class=\"cat-name\">[Electrician]</div>\n              <div class=\"cat-count\">[235] Jobs Available</div>\n            </a>\n          </td>\n          <!-- Finance -->\n          <td width=\"25%\" style=\"padding:0 0 10px 5px;\">\n            <a href=\"[CATEGORY_URL]\" class=\"cat-card\">\n              <div style=\"margin:0 auto;width:36px;height:36px;background:rgba(108,92,231,.08);border-radius:8px;display:flex;align-items:center;justify-content:center;\">\n                <!-- Icon: trending-up -->\n                <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6c5ce7\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\"/><polyline points=\"17 6 23 6 23 12\"/></svg>\