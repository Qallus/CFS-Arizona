# =============================================================================
# SIG360 Production Environment — copy this to .env on your server
# docker-compose reads .env automatically
# In Coolify, paste each variable into the Environment Variables panel instead
# =============================================================================

OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY

# -----------------------------------------------------------------------------
# Next.js / Auth
# -----------------------------------------------------------------------------
AUTH_SECRET=REPLACE_WITH_OUTPUT_OF: openssl rand -base64 32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://sig360.com
NEXT_PUBLIC_APP_URL=https://sig360.com
SIG360_SESSION_SECRET=REPLACE_WITH_OUTPUT_OF: openssl rand -base64 32
SIG360_ADMIN_EMAIL=REPLACE_WITH_ADMIN_EMAIL
SIG360_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
SIG360_ADMIN_NAME=REPLACE_WITH_ADMIN_NAME

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://supabase.cueallus.com
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://supabase.cueallus.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# -----------------------------------------------------------------------------
# Twilio
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=REPLACE_WITH_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+14256001455
TWILIO_SMS_PHONE_NUMBER=+14809999906
TWILIO_TWIML_APP_SID=REPLACE_WITH_TWIML_APP_SID
TWILIO_API_KEY_SID=REPLACE_WITH_API_KEY_SID
TWILIO_API_KEY_SECRET=REPLACE_WITH_API_KEY_SECRET

# -----------------------------------------------------------------------------
# Email (Hostinger IMAP/SMTP)
# -----------------------------------------------------------------------------
EMAIL_ADDRESS=hello@channelcast.io
EMAIL_PASSWORD=REPLACE_WITH_EMAIL_PASSWORD
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
POP_HOST=pop.hostinger.com
POP_PORT=995

# -----------------------------------------------------------------------------
# Square Payments
# -----------------------------------------------------------------------------
SQUARE_APPLICATION_ID=REPLACE_WITH_SQUARE_APP_ID
SQUARE_ACCESS_TOKEN=REPLACE_WITH_SQUARE_ACCESS_TOKEN
SQUARE_LOCATION_ID=REPLACE_WITH_SQUARE_LOCATION_ID
SQUARE_WEBHOOK_SIGNATURE=REPLACE_WITH_WEBHOOK_SIG

# -----------------------------------------------------------------------------
# NocoDB
# -----------------------------------------------------------------------------
NOCODB_BASE_URL=https://nocodb.cueallus.com
NOCODB_API_TOKEN=REPLACE_WITH_NOCODB_TOKEN

# -----------------------------------------------------------------------------
# Cal.com (Self-Hosted)
# -----------------------------------------------------------------------------
CALCOM_BASE_URL=https://meet.cueallus.com
CALCOM_WEBHOOK_SECRET=REPLACE_WITH_CAL_WEBHOOK_SECRET

# -----------------------------------------------------------------------------
# Directus (Self-Hosted)
# -----------------------------------------------------------------------------
DIRECTUS_BASE_URL=https://directus.cueallus.com
DIRECTUS_ADMIN_TOKEN=REPLACE_WITH_DIRECTUS_TOKEN

# -----------------------------------------------------------------------------
# MailPurse
# -----------------------------------------------------------------------------
MAILPURSE_URL=https://send.channelcast.io
MAILPURSE_API_KEY=REPLACE_WITH_MAILPURSE_KEY

# -----------------------------------------------------------------------------
# WordPress (channelcast.io)
# -----------------------------------------------------------------------------
WP_SITE_URL=https://channelcast.io
WP_APPLICATION_USERNAME=channelcastapi
WP_APPLICATION_PASSWORD=REPLACE_WITH_WP_APP_PASSWORD
WP_REST_API_URL=https://channelcast.io/wp-json/wp/v2

# -----------------------------------------------------------------------------
# Redtail CRM
# Server-side only. Do not expose these as NEXT_PUBLIC_* variables.
# Use these to sync Redtail Contacts, Calendar/Activities, Workflows,
# Opportunities, Notes, and User/Team metadata into SIG360.
# -----------------------------------------------------------------------------
REDTAIL_API_BASE_URL=REPLACE_WITH_REDTAIL_API_BASE_URL
REDTAIL_API_KEY=REPLACE_WITH_REDTAIL_API_KEY
REDTAIL_API_SECRET=REPLACE_WITH_REDTAIL_API_SECRET_IF_APPLICABLE
REDTAIL_USERNAME=REPLACE_WITH_REDTAIL_USERNAME_IF_REQUIRED
REDTAIL_PASSWORD=REPLACE_WITH_REDTAIL_PASSWORD_IF_REQUIRED
REDTAIL_DATABASE_ID=REPLACE_WITH_REDTAIL_DATABASE_ID_IF_REQUIRED
REDTAIL_FIRM_ID=REPLACE_WITH_REDTAIL_FIRM_ID_IF_REQUIRED
REDTAIL_WEBHOOK_SECRET=REPLACE_WITH_REDTAIL_WEBHOOK_SECRET_IF_CONFIGURED
REDTAIL_SYNC_ENABLED=false
REDTAIL_SYNC_DIRECTION=redtail_to_sig360
REDTAIL_SYNC_BATCH_SIZE=100
REDTAIL_SYNC_LOOKBACK_DAYS=30
REDTAIL_DEFAULT_CONTACT_STATUS=Client
REDTAIL_DEFAULT_CONTACT_SOURCE=Redtail CRM

# -----------------------------------------------------------------------------
# n8n (Self-Hosted)
# -----------------------------------------------------------------------------
N8N_BASE_URL=https://n8n.cueallus.com
N8N_API_KEY=REPLACE_WITH_N8N_KEY

# -----------------------------------------------------------------------------
# Resend (Email Campaigns)
# -----------------------------------------------------------------------------
RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
