# Hermes Agent Gateway
# In development: http://localhost:18789
# In production (docker-compose): http://hermes:18789
HERMES_GATEWAY_URL=http://localhost:18789
HERMES_GATEWAY_TOKEN=your-strong-random-token-here

# Hermes workspace — shared volume between hermes and sig360 containers
# In development: path to your local hermes workspace
# In production: /hermes/workspace (matches docker-compose volume mount)
HERMES_WORKSPACE=/hermes/workspace

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
SIG360_SESSION_SECRET=generate-with-openssl-rand-base64-32
SIG360_ADMIN_EMAIL=admin@example.com
SIG360_ADMIN_PASSWORD=change-me
SIG360_ADMIN_NAME=Admin

# App domain
NEXT_PUBLIC_APP_URL=https://sig360.com

# Supabase
SUPABASE_URL=https://your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_SMS_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-api-key-secret

# OpenAI (used for transcription / other non-agent features)
OPENAI_API_KEY=sk-proj-...

# Email (IMAP/SMTP)
EMAIL_ADDRESS=hello@sig360.com
EMAIL_PASSWORD=your-email-password
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465

# Square
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_ACCESS_TOKEN=your-access-token
SQUARE_LOCATION_ID=your-location-id
SQUARE_WEBHOOK_SIGNATURE=your-webhook-sig

# Optional integrations
RESEND_API_KEY=re_...
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_API_KEY=your-n8n-key
NOCODB_BASE_URL=https://nocodb.yourdomain.com
NOCODB_API_TOKEN=your-nocodb-token
CALCOM_BASE_URL=https://meet.yourdomain.com
CALCOM_WEBHOOK_SECRET=your-cal-secret
DIRECTUS_BASE_URL=https://directus.yourdomain.com
DIRECTUS_ADMIN_TOKEN=your-directus-token
MAILPURSE_URL=https://your-mailpurse-url
MAILPURSE_API_KEY=your-mailpurse-key
WP_SITE_URL=https://your-wordpress-site.com
WP_APPLICATION_USERNAME=your-wp-user
WP_APPLICATION_PASSWORD=your-app-password
WP_REST_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
