
# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
SIG360_SESSION_SECRET=generate-with-openssl-rand-base64-32
SIG360_ADMIN_EMAIL=admin@example.com
SIG360_ADMIN_PASSWORD=change-me
SIG360_ADMIN_NAME=Admin

# App domain
NEXT_PUBLIC_APP_URL=https://sig360.com

# Supabase
SUPABASE_URL=https://your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_SMS_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-api-key-secret

# OpenAI (used for transcription / other non-agent features)
OPENAI_API_KEY=sk-proj-...

# Email (IMAP/SMTP)
EMAIL_ADDRESS=hello@sig360.com
EMAIL_PASSWORD=your-email-password
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465

# Resend (Transactional Email)
RESEND_API_KEY=re_...

# n8n (Self-Hosted)
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_API_KEY=your-n8n-key

# Cal.com (Self-Hosted)
CALCOM_BASE_URL=https://meet.yourdomain.com
CALCOM_WEBHOOK_SECRET=your-cal-secret

# WordPress
WP_SITE_URL=https://your-wordpress-site.com
WP_APPLICATION_USERNAME=your-wp-user
WP_APPLICATION_PASSWORD=your-app-password
WP_REST_API_URL=https://your-wordpress-site.com/wp-json

# Redtail CRM
# Server-side only. Do not prefix these with NEXT_PUBLIC_.
REDTAIL_API_BASE_URL=https://api.redtailtechnology.com
REDTAIL_API_KEY=your-redtail-api-key
REDTAIL_API_SECRET=your-redtail-api-secret-if-applicable
REDTAIL_USERNAME=your-redtail-username-if-required
REDTAIL_PASSWORD=your-redtail-password-if-required
REDTAIL_DATABASE_ID=your-redtail-database-id-if-required
REDTAIL_FIRM_ID=your-redtail-firm-id-if-required
REDTAIL_WEBHOOK_SECRET=your-redtail-webhook-secret-if-configured
REDTAIL_SYNC_ENABLED=false
REDTAIL_SYNC_DIRECTION=redtail_to_sig360
REDTAIL_SYNC_BATCH_SIZE=100
REDTAIL_SYNC_LOOKBACK_DAYS=30
REDTAIL_DEFAULT_CONTACT_STATUS=Client
REDTAIL_DEFAULT_CONTACT_SOURCE=Redtail CRM
